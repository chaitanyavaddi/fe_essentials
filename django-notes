    # Register your models here.
    admin.site.register(Patient)

  step 6.4 create admin superuser
    python3 manage.py createsuperuser
    #fill username, password, email

  step 6.5 start server and goto /admin & login

  step 6.6 create patient_list inside views.py
  from django.shortcuts import render
  from .models import Patient

  def patient_list(request):
      patients = Patient.objects.all()
      return render(request, 'templates/list.html',  {'patients': patients})

  We dont have any html yet, so create templates folder inside patients
  and lets have lits.html 

  step 6.7 Configure app level URLS
  Two levels of urls - project level and app level
  create urls.py inside patients
  from django.urls import path
  from .views import patient_list
  
  urlpatterns = [
      path('', patient_list)
  ]

   step 6.8 Configure project level urls
   inside medhahms/urls.py
    from django.contrib import admin
    from django.urls import path, include
    
    urlpatterns = [
        path("admin/", admin.site.urls),
        path('patients/', include('patients.urls'))
    ]

